# Monorepo environment template (2026-04-10)
# 참고: apps 별 example 파일이 source of truth 입니다.
# - apps/web/.env.local.example
# - apps/api/.env.example
# - apps/worker/.env.example

# Web / Vercel (apps/web)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3100
RAILWAY_API_URL=
E2E_RAILWAY_API_URL=
FLOORPLAN_UPLOAD_BUCKET=floor-plans
# Required in production/preview for snapshot upload/signing and owner-scope job lookup paths.
SUPABASE_SERVICE_ROLE_KEY=

# Railway API (apps/api)
# Railway injects PORT automatically in production. API_PORT is local fallback.
API_PORT=4000
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CORS_ORIGINS=http://localhost:3100,http://127.0.0.1:3100,https://plan2space.vercel.app,https://plan2-space-web-*.vercel.app,https://plan2space-*.vercel.app
FLOORPLAN_UPLOAD_BUCKET=floor-plans
ENABLE_LIGHTWEIGHT_API_ROUTES=false
ENABLE_LEGACY_API_ROUTES=false

# Railway Worker (apps/worker)
# Worker also requires Supabase + upload bucket keys as explicit runtime inputs.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
FLOORPLAN_UPLOAD_BUCKET=floor-plans
WORKER_CONCURRENCY=2
WORKER_POLL_INTERVAL_MS=1000
FLOORPLAN_PROVIDER_ORDER=anthropic,openai,snaptrude
FLOORPLAN_PREPROCESS_PROFILES=balanced,lineart,filled_plan
FLOORPLAN_PROVIDER_TIMEOUT_MS=45000
FLOORPLAN_MIN_ACCEPT_SCORE=25
FLOORPLAN_REVIEW_SCORE_THRESHOLD=72
FLOORPLAN_REVIEW_CONFLICT_THRESHOLD=0.3
FLOORPLAN_REVIEW_DIMENSION_CONFLICT_THRESHOLD=0.35
FLOORPLAN_REVIEW_SCALE_CONFLICT_THRESHOLD=0.35
ASSET_STORAGE_BUCKET=assets-glb
ASSET_GENERATION_POLL_INTERVAL_MS=2000
ASSET_GENERATION_MAX_POLLS=45
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
SNAPTRUDE_API_URL=
SNAPTRUDE_API_KEY=
ROBOFLOW_CUBICASA2_URL=
ROBOFLOW_CUBICASA3_URL=
ROBOFLOW_API_KEY=
PADDLEOCR_API_URL=
PADDLEOCR_API_TOKEN=
PADDLEOCR_DET_MODEL=PP-OCRv5_det
PADDLEOCR_REC_MODEL=korean_PP-OCRv5_mobile_rec
HF_FLOORPLAN_ENDPOINT_URL=
HF_FLOORPLAN_ENDPOINT_TOKEN=
TRIPOSR_API_URL=
TRIPOSR_API_KEY=
TRIPOSR_STATUS_URL=
MESHY_API_URL=
MESHY_API_KEY=
MESHY_STATUS_URL=

# Optional preprocessing tuning
FLOORPLAN_PREPROCESS_THRESHOLD=200
FLOORPLAN_PREPROCESS_MEDIAN=3
FLOORPLAN_PREPROCESS_BLUR=0.3
FLOORPLAN_PREPROCESS_CONTRAST=1.25
FLOORPLAN_PREPROCESS_BRIGHTNESS=-15
FLOORPLAN_PREPROCESS_LINEART_THRESHOLD=218
FLOORPLAN_PREPROCESS_LINEART_MEDIAN=2
FLOORPLAN_PREPROCESS_LINEART_BLUR=0.15
FLOORPLAN_PREPROCESS_LINEART_CONTRAST=1.45
FLOORPLAN_PREPROCESS_LINEART_BRIGHTNESS=-20
FLOORPLAN_PREPROCESS_FILLED_THRESHOLD=188
FLOORPLAN_PREPROCESS_FILLED_MEDIAN=5
FLOORPLAN_PREPROCESS_FILLED_BLUR=0.9
FLOORPLAN_PREPROCESS_FILLED_CONTRAST=1.6
FLOORPLAN_PREPROCESS_FILLED_BRIGHTNESS=-24
FLOORPLAN_PREPROCESS_FILLED_SHARPEN=1.2
