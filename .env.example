# Monorepo environment template (2026-04-14)
# 앱별 example 파일이 source of truth 입니다.
# - apps/api/.env.example
# - apps/worker/.env.example

# Web / Vercel (apps/web)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3100
RAILWAY_API_URL=
E2E_RAILWAY_API_URL=
SUPABASE_SERVICE_ROLE_KEY=
PROJECT_MEDIA_BUCKET=project-media

# Railway API (apps/api)
API_PORT=4000
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CORS_ORIGINS=http://localhost:3100,http://127.0.0.1:3100,https://plan2space.vercel.app,https://plan2-space-web-*.vercel.app,https://plan2space-*.vercel.app

# Railway Worker (apps/worker)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ASSET_STORAGE_BUCKET=assets-glb
WORKER_CONCURRENCY=2
WORKER_POLL_INTERVAL_MS=1000
ASSET_GENERATION_POLL_INTERVAL_MS=2000
ASSET_GENERATION_MAX_POLLS=45
TRIPOSR_API_URL=
TRIPOSR_API_KEY=
TRIPOSR_STATUS_URL=
MESHY_API_URL=
MESHY_API_KEY=
MESHY_STATUS_URL=
